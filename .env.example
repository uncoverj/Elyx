# Shared
APP_ENV=dev
BOT_TOKEN=replace_me
SERVICE_TOKEN=local-service-token

# Backend
# In dev you can keep DATABASE_URL empty and backend will auto-use sqlite+aiosqlite:///./elyx.db
# If DATABASE_URL points to docker host "postgres", backend also auto-falls back to SQLite in dev.
# In prod set APP_ENV=prod and provide a reachable PostgreSQL URL.
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0
CORS_ORIGIN=*

# Bot
BACKEND_URL=http://127.0.0.1:8000
WEBAPP_URL=http://localhost:3000

# WebApp
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
